# Copy to backend/.env (or set in your host dashboard). Never commit real secrets.

DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# SQLite locally; Postgres on Render etc.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

TMDB_API_KEY=

# Comma-separated origins for the Next.js app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Optional: when DEBUG is False, set true only if you intentionally need open CORS
# CORS_ALLOW_ALL=false
